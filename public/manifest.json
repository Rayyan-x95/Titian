{
  "name": "Titan Productivity & Finance",
  "short_name": "Titan",
  "description": "Titan is an offline-first productivity app for task management, notes, and expense tracking. A free personal organizer that works without internet.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0a1018",
  "theme_color": "#0a1018",
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "New Task",
      "description": "Create a new task",
      "url": "/tasks?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "New Note",
      "short_name": "New Note",
      "description": "Create a new note",
      "url": "/notes?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Add Expense",
      "short_name": "Expense",
      "description": "Add a new expense",
      "url": "/finance?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Today's Tasks",
      "short_name": "Tasks",
      "description": "View today's tasks",
      "url": "/tasks?date=today",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Weekly Review",
      "short_name": "Review",
      "description": "Weekly review and summary",
      "url": "/finance?week=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "text": "text",
      "title": "title"
    }
  },
  "icons": [
    {
      "src": "/icons/titan-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/titan-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
