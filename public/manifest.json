{
  "name": "Titan",
  "short_name": "Titan",
  "description": "Titan is an installable, offline-first productivity app for tasks, notes, and finance.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0a1018",
  "theme_color": "#0a1018",
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "New Task",
      "description": "Create a new task",
      "url": "/tasks?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "New Note",
      "short_name": "New Note",
      "description": "Create a new note",
      "url": "/notes?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Add Expense",
      "short_name": "Expense",
      "description": "Add a new expense",
      "url": "/finance?new=1",
      "icons": [{ "src": "/icons/titan-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "icons": [
    {
      "src": "/icons/titan-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/titan-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
